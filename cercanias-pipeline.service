[Unit]
Description=Cercanías Renfe — Pipeline de ingesta GTFS-RT
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/cercanias
ExecStart=/root/cercanias/venv/bin/python main.py
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
